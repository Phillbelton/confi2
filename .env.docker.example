# ==========================================================
# Variables que lee DOCKER COMPOSE (no el backend).
# Copia este archivo a ".env" en la raiz y completa los valores.
#   cp .env.docker.example .env
# ==========================================================

# --- MongoDB (contenedor local) ---
# Deben COINCIDIR con el MONGODB_URI de backend/.env.production
MONGO_USER=quelita
MONGO_PASSWORD=cambia_esta_password_de_mongo

# --- Frontend (se hornean en el build de Next) ---
# URL RELATIVA: el navegador llama al MISMO origen por donde entró (IP, túnel o dominio).
# Así funciona detrás de Cloudflare Tunnel sin rebuild, y arregla el preview del admin.
# Caddy enruta /api -> backend y /uploads -> volumen.
NEXT_PUBLIC_API_URL=/api
# SITE_URL: solo para sitemap/robots (SEO). No es crítico para el demo. Pon tu IP/dominio.
NEXT_PUBLIC_SITE_URL=http://192.168.5.173
NEXT_PUBLIC_WHATSAPP_NUMBER=56920178216
