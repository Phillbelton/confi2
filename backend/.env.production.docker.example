# ==========================================================
# Backend en Docker (VM local). Copia a backend/.env.production
#   cp backend/.env.production.docker.example backend/.env.production
# ==========================================================

NODE_ENV=production
PORT=5000

# --- Mongo del contenedor ---
# usuario:password DEBEN coincidir con MONGO_USER/MONGO_PASSWORD del .env de la raiz.
# 'mongo' es el nombre del servicio en docker-compose (DNS interno).
MONGODB_URI=mongodb://quelita:cambia_esta_password_de_mongo@mongo:27017/confiteria_quelita?authSource=admin
DB_NAME=confiteria_quelita

# --- URLs (IP de tu VM) ---
BACKEND_URL=http://192.168.5.172
FRONTEND_URL=http://192.168.5.172

# --- JWT ---
# GENERA cada uno (DISTINTOS) con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- Uploads (coincide con el volumen del contenedor) ---
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# --- Imagenes LOCALES en el VPS (no Cloudinary) ---
USE_CLOUDINARY=false

# --- WhatsApp ---
WHATSAPP_BUSINESS_PHONE=56920178216

# --- Admin inicial (lo crea: node dist/scripts/seedAdmin.js) ---
# Debe cumplir: >=8 chars, mayus + minus + numero + caracter especial.
DEFAULT_ADMIN_EMAIL=admin@quelita.com
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=Administrador Quelita

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
